# DeepSeek chat inference
# Required: server-side only. Never expose this with NEXT_PUBLIC_.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Optional overrides. Defaults are already set in src/app/api/deepseek/send/route.ts.
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL_ID=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=max

# Optional image-to-LaTeX transcription before DeepSeek.
# Use the API key you created in Google AI Studio.
GEMINI_OCR_API_KEY=your-google-ai-studio-api-key
GEMINI_OCR_MODEL_ID=gemini-3.1-flash-lite
